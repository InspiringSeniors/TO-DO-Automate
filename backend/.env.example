# ── Database ───────────────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
# Use a Gmail App Password, NOT your real password
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_EMAIL=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key   # required for file uploads
SUPABASE_STORAGE_BUCKET=internal-resources

# ── CORS (comma-separated origins, no trailing slash) ─────────────────────────
# Dev default: http://localhost:5173
# Production:  https://yourapp.vercel.app,https://yourapp.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Production tuning (all optional) ──────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=2        # gunicorn workers (default: cpu_count)
LOG_LEVEL=info
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# DISABLE_DOCS=1         # uncomment to hide /docs and /redoc in production
